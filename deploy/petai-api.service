[Unit]
Description=PetAI Mind API (FastAPI)
After=network.target docker.service
Requires=docker.service

[Service]
User=root
WorkingDirectory=/var/www/AIPET/apps/api
ExecStart=/var/www/AIPET/apps/api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8001 --workers 1
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
